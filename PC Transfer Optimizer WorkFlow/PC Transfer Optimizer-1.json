      "id": "1b9e1a44-7e16-4c8a-8867-e269962e43b1",
      "name": "Code in JavaScript10"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet allRecords = [];\nfor (const item of items) {\n  const text = item.json.choices[0].message.content.trim(); // adjust path to match your LLM node's output shape\n  const lines = text.split(\"\\n\").filter(l => l.trim());\n  for (const line of lines) {\n    const [sn, emp_no, name, grade, current, newloc, func, remarks] = line.split(\"|\");\n    allRecords.push({ sn, emp_no, name, grade, current_location: current, new_location: newloc, new_function: func, remarks });\n  }\n}\nreturn [{ json: { transfers: allRecords } }];"
      },
