        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n{\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Parse OCR table rows into pipe-delimited records. Each input line is one row: space-separated x0:word tokens sorted left-to-right. Columns left-to-right: SN, EMPID, NAME, GRADE, CURRENT, NEW, FUNCTION, REMARKS. Multi-word values (names, plant/city names like 'DABHOL KLL') stay in one field. Grade is always 2 chars: E or S + digit. Output exactly one line per input row: SN|EMPID|NAME|GRADE|CURRENT|NEW|FUNCTION|REMARKS. Leave a field blank if absent. No headers, no explanations, no markdown.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": `${$json.rows}`\n    }\n  ],\n  \"temperature\": 0,\n  \"response_format\": { \"type\": \"text\" }\n}\n}}",
        "options": {
