    {
      "parameters": {
        "jsCode": "const result = $input.first().json // response is an array with one object\nconst rows = [];\n\n// Two-way swaps\nfor (const swap of result.two_way_swaps ?? []) {\n  for (const t of swap.transfers) {\n    rows.push({\n      type: \"2-way swap\",\n      cycle_id: swap.cycle_id,\n      employee_id: t.employee_id,\n      employee_name: t.employee_name,\n      from_location: t.from_location,\n      to_location: t.to_location,\n      reason: swap.reason\n    });\n  }\n}\n\n// Three-way swaps\nfor (const swap of result.three_way_swaps ?? []) {\n  for (const t of swap.transfers) {\n    rows.push({\n      type: \"3-way swap\",\n      cycle_id: swap.cycle_id,\n      employee_id: t.employee_id,\n      employee_name: t.employee_name,\n      from_location: t.from_location,\n      to_location: t.to_location,\n      reason: swap.reason\n    });\n  }\n}\n\n// Surplus transfers (bulk city-to-city shipments)\nfor (const s of result.surplus_transfers ?? []) {\n  rows.push({\n    type: \"Surplus transfer\",\n    cycle_id: \"\",\n    employee_id: \"\",\n    employee_name: \"\",\n    from_location: s.from_location,\n    to_location: s.to_location,\n    quantity: s.quantity,\n    reason: \"City needs PC — surplus routing\"\n  });\n}\n\n// Unresolved transfers\nfor (const t of result.unresolved_transfers ?? []) {\n  rows.push({\n    type: \"Unresolved\",\n    cycle_id: \"\",\n    employee_id: t.employee_id,\n    employee_name: t.employee_name,\n    from_location: t.from_location,\n    to_location: t.to_location,\n    reason: \"No match found\"\n  });\n}\n\nreturn rows.map(r => ({ json: r }));"
      },
