      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst items = $input.all();\n\nfor (const item of items) {\n  const name = item.json.plant_name;\n  staticData.geocodeCache[name] = {\n    latitude: item.json.latitude,\n    longitude: item.json.longitude\n  };\n}\n\nreturn items;"
