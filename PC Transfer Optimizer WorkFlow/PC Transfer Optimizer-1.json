    {
      "parameters": {
        "jsCode": "// Mode: \"Run Once for All Items\"\nconst items = $input.all(); // one item per PDF document\nconst pageItems = [];\n\nfor (const item of items) {\n  const doc = item.json; // { source_filename, page_width, num_pages, pages, total_candidate_rows }\n  for (const page of doc.pages) {\n    pageItems.push({\n      json: {\n        source_filename: doc.source_filename,\n        page_number: page.page_number,\n        rows: page.rows\n      }\n    });\n  }\n}\n\nreturn pageItems;"
      },
