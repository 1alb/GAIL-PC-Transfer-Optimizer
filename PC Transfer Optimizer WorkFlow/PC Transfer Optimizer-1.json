    {
      "parameters": {
        "jsCode": "// Enable \"Execute Once\" in node Settings so this runs on the full batch,\n// not once per PDF item.\nconst items = $input.all();\n\nconst plantSet = new Set();\nfor (const item of items) {\n  const transfers = item.json.transfers || [];\n  for (const transfer of transfers) {\n    if (transfer.current_location) {\n      plantSet.add(\n        transfer.current_location\n          .replace(/\\s+Plant$/i, \"\")\n          .trim()\n      );\n    }\n    if (transfer.new_location) {\n      plantSet.add(\n        transfer.new_location\n          .replace(/\\s+Plant$/i, \"\")\n          .trim()\n      );\n    }\n  }\n}\n\nreturn [...plantSet].map(name => {\n  const firstPart = name.split(/[\\s-]+/)[0];\n  return {\n    json: {\n      plant_name: name,\n      search_query: `${firstPart}, India`\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -880,
        -336
      ],
      "id": "16ca20b8-24a4-4070-b137-329f888fac30",
      "name": "Code in JavaScript11"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const MANUAL_COORDINATES = {\n  \"ADIYAKAMANGALAM\": { latitude: 10.761814, longitude: 79.678294 },\n};\n\nconst plantName = $('Code in JavaScript11').item.json.plant_name;\nconst location = $json.results[0];\n\n// Manual override takes priority — skip geocoding result entirely if we have one\nif (MANUAL_COORDINATES[plantName]) {\n  return {\n    json: {\n      plant_name: plantName,\n      latitude: MANUAL_COORDINATES[plantName].latitude,\n      longitude: MANUAL_COORDINATES[plantName].longitude,\n      geocode_failed: false,\n      manually_corrected: true,\n      originalData: $('Code in JavaScript11').item.json.originalData\n    }\n  };\n}\n\nif (location.components._type === 'country') {\n  return {\n    json: {\n      plant_name: plantName,\n      latitude: null,\n      longitude: null,\n      geocode_failed: true,\n      originalData: $('Code in JavaScript11').item.json.originalData\n    }\n  };\n}\n\nreturn {\n  json: {\n    plant_name: plantName,\n    latitude: Number(location.geometry.lat),\n    longitude: Number(location.geometry.lng),\n    geocode_failed: false,\n    originalData: $('Code in JavaScript11').item.json.originalData\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -528,
        -80
      ],
      "id": "874b54a2-138a-4587-b4a4-dca74c777c3a",
      "name": "Code in JavaScript13"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst coordMap = {};\nfor (const item of items) {\n  coordMap[item.json.plant_name] = {\n    latitude: item.json.latitude,\n    longitude: item.json.longitude\n  };\n}\n\nconst allTransfers = $('Parse LLM output').first().json?.transfers ?? [];\n\nconst transfers = allTransfers.map(t => {\n  const fromKey = t.current_location;\n  const toKey = t.new_location;\n  return {\n    employee_id: t.emp_no,\n    employee_name: t.name,\n    from_location: fromKey,\n    to_location: toKey,\n    from_coords: coordMap[fromKey] ?? null,\n    to_coords: coordMap[toKey] ?? null,\n  };\n});\n\nreturn [{ json: { transfers } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -112,
